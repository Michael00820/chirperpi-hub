# =============================================================================
# ChirperPi Hub - Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server port (default: 3001)
PORT=3001

# Server environment (development, production, staging)
NODE_ENV=development

# Server hostname/URL for CORS and deployment
SERVER_URL=http://localhost:3001

# =============================================================================
# CLIENT CONFIGURATION
# =============================================================================

# Frontend URL for CORS validation
FRONTEND_URL=http://localhost:5173
# Legacy alias if needed
CLIENT_URL=http://localhost:5173

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/chirperpi

# =============================================================================
# REDIS (Session & Cache)
# =============================================================================

# Redis connection URL for sessions and token blacklist
REDIS_URL=redis://localhost:6379

# Redis password (if required)
REDIS_PASSWORD=

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT secret for access tokens (15 minute expiry)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here-generate-with-crypto-randomBytes

# JWT secret for refresh tokens (7 day expiry)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=your-refresh-secret-key-here-generate-with-crypto-randomBytes

# Session secret for express-session
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-key-here-generate-with-crypto-randomBytes

# CSRF protection secret
CSRF_SECRET=your-csrf-secret-key-here

# =============================================================================
# PI NETWORK (Authentication & Payments)
# =============================================================================

# Pi Network API Key
PI_API_KEY=your-pi-api-key

# Pi Network API Secret
PI_SECRET=your-pi-secret

# Pi Network Platform API URL
PI_PLATFORM_API_URL=https://api.pi.network/v2

# Pi Wallet Address (for receiving payments)
PI_WALLET_ADDRESS=your-pi-wallet-address

# =============================================================================
# PINATA (IPFS Storage)
# =============================================================================

# Pinata API Key for IPFS file uploads
PINATA_API_KEY=your-pinata-api-key

# Pinata API Secret
PINATA_API_SECRET=your-pinata-api-secret

# Pinata JWT Token (optional, for gateway access)
PINATA_JWT_TOKEN=

# =============================================================================
# EMAIL & NOTIFICATIONS
# =============================================================================

# SMTP Configuration for emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email from address
EMAIL_FROM=noreply@chirperpi.com

# =============================================================================
# PUSH NOTIFICATIONS
# =============================================================================

# Web Push VAPID Public Key
VAPID_PUBLIC_KEY=

# Web Push VAPID Private Key
VAPID_PRIVATE_KEY=

# Subject for push notifications (usually your app URL)
VAPID_SUBJECT=mailto:your-email@example.com

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Sentry DSN for error tracking and monitoring
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Sentry environment
SENTRY_ENVIRONMENT=development

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# =============================================================================
# PAYMENT & TRANSACTION SETTINGS
# =============================================================================

# Minimum Pi amount for transactions (in Pi)
MIN_PI_AMOUNT=0.01

# Maximum Pi amount for transactions (in Pi)
MAX_PI_AMOUNT=1000

# Transaction fee percentage (0.05 = 5%)
TRANSACTION_FEE_PERCENT=0.05

# =============================================================================
# RATE LIMITING & SECURITY
# =============================================================================

# General API rate limit requests per minute
API_RATE_LIMIT_PER_MINUTE=100

# Auth endpoint rate limit requests per minute
AUTH_RATE_LIMIT_PER_MINUTE=10

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable messaging feature
MESSAGING_ENABLED=true

# Enable/disable governance feature
GOVERNANCE_ENABLED=true

# Enable/disable transactions feature
TRANSACTIONS_ENABLED=true

# Enable/disable group feature
GROUPS_ENABLED=true

# =============================================================================
# DATABASE MIGRATION
# =============================================================================

# Automatically run migrations on startup
AUTO_MIGRATE=true

# =============================================================================
# BACKUP & MAINTENANCE
# =============================================================================

# S3 backup bucket (optional)
AWS_S3_BUCKET=

# AWS access key ID
AWS_ACCESS_KEY_ID=

# AWS secret access key
AWS_SECRET_ACCESS_KEY=

# AWS region
AWS_REGION=us-east-1

# Backup interval in hours
BACKUP_INTERVAL_HOURS=24

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug logging
DEBUG=false

# Enable CORS in development
DEV_CORS=true

# Allow test data seeding
ALLOW_TEST_DATA=false
